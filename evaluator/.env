# Absolute path to the project root on the host.
# Must match the location of this directory's parent, because the portal
# backend bind-mounts the project at the SAME absolute path inside its
# container (required for docker-outside-of-docker compose bind mounts to
# resolve correctly).
PROJECT_ROOT=/c/Users/petre/Documents/Licenta2026

# Optional: pass API keys through to the level stacks started by the portal.
# Uncomment and fill in if you want level4 / evaluator to pick them up.
# ANTHROPIC_API_KEY=

# --- Evaluator (Kimi K2.5 via Moonshot) ---
# Moonshot API key — required for the /evaluate endpoint to return scorecards.
# Without it the evaluator starts but /health reports available=false and any
# /evaluate call returns 503.
# EVALUATOR_API_KEY=sk-...

# Alternative: run the evaluator against a local Ollama Cloud proxy instead of
# Moonshot directly. Uncomment both lines to switch providers.
EVALUATOR_BASE_URL=http://host.docker.internal:11434/v1
EVALUATOR_MODEL=kimi-k2.5:cloud
# Ollama Cloud doesn't require a real key but the OpenAI client needs a
# non-empty value to send as the Bearer token.
EVALUATOR_API_KEY=ollama