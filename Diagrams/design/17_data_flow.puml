@startuml data_flow
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam shadowing false
skinparam roundCorner 10

title **Data Flow — Cumulative Routing**\n//Each agent receives all prior outputs//

left to right direction

rectangle "Client Question" as input #F5F5F5

rectangle "Engagement\nManager" as em #E3F2FD
rectangle "Market\nResearcher" as mr #E8F5E9
rectangle "Financial\nAnalyst" as fa #FFF3E0
rectangle "Risk\nAnalyst" as ra #FFEBEE
rectangle "Strategy\nConsultant" as sc #F3E5F5
rectangle "Evaluator" as ev #FFFDE7

card "Analysis\nPlan" as plan #BBDEFB
card "Market\nAnalysis" as mdata #C8E6C9
card "Financial\nAnalysis" as fdata #FFE0B2
card "Risk\nMatrix" as rdata #FFCDD2
card "Consulting\nReport" as report #E1BEE7
card "Evaluation\nScorecard" as score #FFF9C4

input --> em
em --> plan

plan --> mr
mr --> mdata

plan --> fa
mdata --> fa
fa --> fdata

plan --> ra
mdata --> ra
fdata --> ra
ra --> rdata

plan --> sc
mdata --> sc
fdata --> sc
rdata --> sc
sc --> report

report --> ev
ev --> score

note as N1
  **Cumulative Data Routing:**
  ----
  MR: sees analysis plan
  FA: sees plan + market analysis
  RA: sees plan + market analysis + financial analysis
  SC: sees plan + all three analyses
  Evaluator: sees only the consulting report
  ----
  //Data accumulates as it flows downstream//
  //No agent can modify prior outputs//
end note

@enduml
