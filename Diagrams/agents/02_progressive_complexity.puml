@startuml progressive_complexity
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam shadowing false
skinparam roundCorner 8

title **Progressive Complexity — 4 Levels of Agent Organization**

skinparam rectangle {
  FontColor #1A1A1A
}

' === LEVEL 1 ===
rectangle "**Level 1 — Single Agent (Baseline)**" as L1 #E3F2FD {
  rectangle "Generic Agent\n(No specialization)" as l1a #BBDEFB
  note right of l1a
    1 agent, 1 model (qwen2.5:14b)
    No role separation
    No evaluation
  end note
}

' === LEVEL 2 ===
rectangle "**Level 2 — Four Agents (Core Roles)**" as L2 #E8F5E9 {
  rectangle "Engagement\nManager" as l2em #C8E6C9
  rectangle "Market\nResearcher" as l2mr #C8E6C9
  rectangle "Strategy\nConsultant" as l2sc #C8E6C9
  rectangle "Evaluator" as l2ev #C8E6C9
  l2em -right-> l2mr : "plan"
  l2mr -right-> l2sc : "findings"
  l2sc -right-> l2ev : "report"
}

' === LEVEL 3 ===
rectangle "**Level 3 — Five Agents (Full Specialization)**" as L3 #FFF3E0 {
  rectangle "Engagement\nManager" as l3em #FFE0B2
  rectangle "Market\nResearcher" as l3mr #FFE0B2
  rectangle "Financial\nAnalyst" as l3fa #FFE0B2
  rectangle "Risk\nAnalyst" as l3ra #FFE0B2
  rectangle "Strategy\nConsultant" as l3sc #FFE0B2

  l3em -right-> l3mr : "plan"
  l3mr -right-> l3fa : "plan +\nmarket"
  l3fa -right-> l3ra : "plan + market\n+ financial"
  l3ra -right-> l3sc : "all analyses"
}

' === LEVEL 4 ===
rectangle "**Level 4 — Five Agents + EM Review + Evaluator\n(Hybrid Hierarchical)**" as L4 #FFEBEE {
  rectangle "EM" as l4em #FFCDD2
  rectangle "MR" as l4mr #FFCDD2
  rectangle "FA" as l4fa #FFCDD2
  rectangle "RA" as l4ra #FFCDD2
  rectangle "SC" as l4sc #FFCDD2
  rectangle "Evaluator" as l4ev #FFCDD2

  l4em -right-> l4mr
  l4mr -right-> l4em : "review"
  l4em -right-> l4fa
  l4fa -right-> l4em : "review"
  l4em -right-> l4ra
  l4ra -right-> l4em : "review"
  l4em -right-> l4sc
  l4sc -right-> l4em : "review"
  l4em -right-> l4ev

  note bottom of L4
    Sequential pipeline + EM review
    after each agent (max 1 revision)
  end note
}

L1 -[hidden]down- L2
L2 -[hidden]down- L3
L3 -[hidden]down- L4

@enduml
