@startuml level3_five_agents
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam shadowing false
skinparam roundCorner 10
skinparam componentStyle rectangle

title **Level 3 — Five Agents (Full Specialization)**

skinparam component {
  FontColor #1A1A1A
}

actor "Client" as client

package "Orchestrator (Python — No LLM)" as orch #F5F5F5 {
  component "Task Router" as router
  component "Validation\n& Schema\nEnforcer" as val
}

component "**Engagement Manager**\n//qwen3:8b (Ollama)//\n\nDecomposes question into\nworkstreams & assignments\n----\nTools: none\nOutput: Analysis Plan JSON" as em #E3F2FD

component "**Market Researcher**\n//qwen3:14b (Ollama)//\n\nMarket size, competitors,\ntrends, customer segments\n----\nTools: search_web(), read_document()\nOutput: Market Analysis JSON" as mr #E8F5E9

component "**Financial Analyst**\n//deepseek-r1:14b (Ollama)//\n\nCosts, revenue, ROI,\nbreak-even, sensitivity\n----\nTools: none (analysis from context,\nuses /think mode)\nOutput: Financial Analysis JSON" as fa #FFF3E0

component "**Risk Analyst**\n//qwen3:14b (Ollama)//\n\nRegulatory, market, operational,\ncompetitive risks\n----\nTools: search_web(), read_document(),\nassess_risk()\nOutput: Risk Matrix JSON" as ra #FFEBEE

component "**Strategy Consultant**\n//qwen3:32b (Ollama)//\n\nSynthesizes all inputs into\nfinal recommendation with options\n----\nTools: reads all analyses from context\nOutput: Consulting Report JSON" as sc #F3E5F5

client -down-> router : "business\nquestion"
router -down-> em : "route"

em -down-> val : "analysis plan"
val -down-> mr : "plan"

mr -down-> val : "market\nanalysis"
val -down-> fa : "plan +\nmarket analysis"

fa -down-> val : "financial\nanalysis"
val -down-> ra : "plan + market\n+ financial"

ra -down-> val : "risk\nassessment"
val -down-> sc : "all validated\nanalyses"

sc -down-> client : "consulting\nreport"

note bottom
  **Sequential Pipeline — Cumulative Data Routing**
  EM → MR → FA → RA → SC
  Each agent receives all prior outputs.
  All models run locally via Ollama.
end note

@enduml
