@startuml l3_data_routing
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam shadowing false
skinparam roundCorner 10

title **Level 3 — Data Routing**\n//Cumulative routing across 5 agents//

left to right direction

rectangle "Client Question" as input #F5F5F5

rectangle "Engagement\nManager\n(qwen3:8b)" as em #E3F2FD
rectangle "Market\nResearcher\n(qwen3:14b)" as mr #E8F5E9
rectangle "Financial\nAnalyst\n(deepseek-r1:14b)" as fa #FFF3E0
rectangle "Risk\nAnalyst\n(qwen3:14b)" as ra #FFEBEE
rectangle "Strategy\nConsultant\n(qwen3:32b)" as sc #F3E5F5
rectangle "Evaluator\n(gemini-2.5-flash)" as ev #FFFDE7

card "Analysis\nPlan" as plan #BBDEFB
card "Market\nAnalysis" as mdata #C8E6C9
card "Financial\nAnalysis" as fdata #FFE0B2
card "Risk\nMatrix" as rdata #FFCDD2
card "Consulting\nReport" as report #E1BEE7
card "Evaluation\nScorecard" as score #FFF9C4

input --> em
em --> plan

plan --> mr
mr --> mdata

plan --> fa
mdata --> fa
fa --> fdata

plan --> ra
mdata --> ra
fdata --> ra
ra --> rdata

plan --> sc
mdata --> sc
fdata --> sc
rdata --> sc
sc --> report

report --> ev
ev --> score

note as N1
  **Level 3 Data Routing:**
  ----
  EM: sees client question only
  MR: sees question + analysis plan
  FA: sees plan + market analysis
  RA: sees plan + market + financial analysis
  SC: sees plan + all three analyses
  Evaluator: sees question + consulting report
  ----
  //Data accumulates downstream//
  //No agent can modify prior outputs//
end note

@enduml
