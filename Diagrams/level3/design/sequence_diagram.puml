@startuml l3_sequence
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam shadowing false
skinparam roundCorner 8
skinparam sequenceMessageAlign center

title **Level 3 — Execution Sequence**\n//5-Agent Sequential Pipeline//

actor Client as client
participant "Orchestrator" as orch #F5F5F5
participant "Engagement\nManager\n(qwen3:8b)" as em #E3F2FD
participant "Market\nResearcher\n(qwen3:14b)" as mr #E8F5E9
participant "Financial\nAnalyst\n(deepseek-r1:14b)" as fa #FFF3E0
participant "Risk\nAnalyst\n(qwen3:14b)" as ra #FFEBEE
participant "Strategy\nConsultant\n(qwen3:32b)" as sc #F3E5F5
participant "Evaluator\n(gemini-2.5-flash)" as ev #FFFDE7
database "SQLite" as db

client -> orch : Business question
orch -> db : log(session_start)

== Phase 1: Task Decomposition ==

orch -> em : question
activate em
em --> orch : Analysis Plan JSON
deactivate em
orch -> orch : validate(AnalysisPlanSchema)

== Phase 2: Market Research ==

orch -> mr : question + plan
activate mr
note right of mr
  Research loop (max 8 rounds)
  search_web() → read_document()
end note
mr --> orch : Market Analysis JSON
deactivate mr
orch -> orch : validate(MarketAnalysisSchema)

== Phase 3: Financial Analysis ==

orch -> fa : question + plan + market_analysis
activate fa
note right of fa
  **DeepSeek R1** chain-of-thought:
  Explicit <think> tags show
  every calculation step
end note
fa --> orch : Financial Analysis JSON
deactivate fa
orch -> orch : validate(FinancialAnalysisSchema)

== Phase 4: Risk Assessment ==

orch -> ra : question + plan + market + financial
activate ra
note right of ra
  search_web() + read_document()
  + assess_risk() tool
end note
ra --> orch : Risk Assessment JSON
deactivate ra
orch -> orch : validate(RiskAssessmentSchema)

== Phase 5: Report Synthesis (Streamed) ==

orch -> sc : question + plan + all analyses
activate sc
loop for each token
  sc --> orch : streaming token
  orch --> client : SSE: {type: "token"}
end
sc --> orch : report complete
deactivate sc

== Phase 6: Evaluation ==

orch -> ev : question + report
activate ev
ev --> orch : Scorecard JSON\n(6 criteria × 1-10)
deactivate ev

orch -> client : SSE: {type: "done", scorecard}

@enduml
